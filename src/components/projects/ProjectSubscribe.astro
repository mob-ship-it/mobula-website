---
import { Image } from 'astro:assets';
import vector22 from '../../assets/images/projects/legal-law-office/Vector 22.png';

interface Props {
  banner: string;
  ctaLabel: string;
  ctaHref: string;
}

const { banner, ctaLabel, ctaHref } = Astro.props;
---

<div class="relative bg-[#211ee1] rounded-3xl overflow-hidden mb-12">
  <div class="relative z-10 px-8 py-10 md:px-12 md:py-12 lg:py-16">
    <h2 class="[font-family:'Bricolage_Grotesque',Helvetica] font-bold text-white text-3xl md:text-4xl lg:text-5xl leading-tight mb-6 text-left">
      {banner}
    </h2>
    <a
      href={ctaHref}
      class="inline-block bg-white text-[#211ee1] [font-family:'Bricolage_Grotesque',Helvetica] font-semibold text-lg md:text-xl px-10 md:px-12 py-3.5 md:py-4 rounded-full hover:bg-[#faf1ea] transition-colors duration-300"
    >
      {ctaLabel}
    </a>
  </div>

  <div class="pointer-events-none absolute inset-y-0 right-0 hidden md:flex items-center">
    <Image
      src={vector22}
      alt=""
      width={700}
      height={700}
      class="h-[140%] w-auto -mr-10 -rotate-90"
      loading="lazy"
    />
  </div>
  <div class="absolute bottom-0 left-0 right-0 md:hidden">
    <Image
      src={vector22}
      alt=""
      width={1200}
      height={200}
      class="w-full h-auto"
      loading="lazy"
    />
  </div>
</div>
