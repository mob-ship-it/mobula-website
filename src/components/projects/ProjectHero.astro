---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  desktop: ImageMetadata;
  mobile: ImageMetadata;
  alt: string;
}

const { desktop, mobile, alt } = Astro.props;

/** Same frame as legacy heroes (~1224x628 desktop, square mobile). */
const desktopAspect = 'lg:aspect-[1.95]';
---

<div class="mb-10 w-full">
  <div class={`relative w-full rounded-3xl overflow-hidden shadow-2xl aspect-square ${desktopAspect}`}>
    <Image
      src={desktop}
      alt={alt}
      width={1224}
      height={628}
      format="webp"
      quality={90}
      class="hidden lg:block absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    <Image
      src={mobile}
      alt={alt}
      width={800}
      height={800}
      format="webp"
      quality={90}
      class="lg:hidden absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
  </div>
</div>
