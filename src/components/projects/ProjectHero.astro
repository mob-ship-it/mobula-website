---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  desktop: ImageMetadata;
  mobile: ImageMetadata;
  alt: string;
}

const { desktop, mobile, alt } = Astro.props;
---

<div class="mb-10">
  <div class="relative rounded-3xl overflow-hidden shadow-2xl">
    <Image
      src={desktop}
      alt={alt}
      width={1600}
      height={1000}
      format="webp"
      quality={90}
      class="hidden lg:block w-full h-auto object-cover"
      loading="eager"
    />
    <Image
      src={mobile}
      alt={alt}
      width={800}
      height={1000}
      format="webp"
      quality={90}
      class="lg:hidden w-full h-auto object-cover"
      loading="eager"
    />
  </div>
</div>
