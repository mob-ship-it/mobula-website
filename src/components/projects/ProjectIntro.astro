---
import { Image } from 'astro:assets';
import type { ProjectIntro as ProjectIntroData } from '../../data/projects/types';
import ProjectMeta from './ProjectMeta.astro';

interface Props {
  intro: ProjectIntroData;
  year: string;
  siteUrl?: string;
  lang: 'es' | 'en';
  visitSiteLabel: string;
  yearLabel: string;
  industryLabel: string;
  keyResultsLabel: string;
}

const {
  intro,
  year,
  siteUrl,
  lang,
  visitSiteLabel,
  yearLabel,
  industryLabel,
  keyResultsLabel,
} = Astro.props;

const title = intro.title[lang];
const paragraphs = intro.paragraphs[lang];
const industry = intro.industry[lang];
---

{intro.variant === 'withImage' ? (
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-stretch mb-10">
    <div class="lg:col-span-7">
      <div class="flex flex-col lg:flex-row lg:items-start lg:gap-4 mb-4">
        <h1 class="[font-family:'Bricolage_Grotesque',Helvetica] font-bold text-[#13243c] text-3xl md:text-4xl lg:text-5xl leading-tight text-center lg:text-left">
          {title}
        </h1>
        {siteUrl && (
          <a
            href={siteUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="hidden lg:inline-flex items-center gap-2 bg-white text-[#211ee1] [font-family:'Bricolage_Grotesque',Helvetica] font-semibold text-sm px-5 py-2 rounded-full hover:bg-[#faf1ea] transition-colors whitespace-nowrap self-start mt-1"
          >
            <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M14 3h7v7M10 14L21 3M21 21H3V3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            {visitSiteLabel}
          </a>
        )}
      </div>
      {siteUrl && (
        <div class="mt-4 lg:hidden text-center">
          <a
            href={siteUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-white text-[#211ee1] [font-family:'Bricolage_Grotesque',Helvetica] font-semibold text-base md:text-lg px-6 py-2 rounded-full hover:bg-[#faf1ea] transition-colors"
          >
            <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M14 3h7v7M10 14L21 3M21 21H3V3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            {visitSiteLabel}
          </a>
        </div>
      )}
      {paragraphs.map((p, i) => (
        <p
          class:list={[
            "[font-family:'Be_Vietnam',Helvetica] text-[#13243c] text-base md:text-lg leading-relaxed max-w-2xl mx-auto lg:mx-0 text-center lg:text-left",
            i < paragraphs.length - 1 ? 'mb-4' : 'mb-0',
          ]}
        >
          {p}
        </p>
      ))}
      <ProjectMeta
        year={year}
        industry={industry}
        yearLabel={yearLabel}
        industryLabel={industryLabel}
        class="hidden lg:grid mt-8"
      />
    </div>
    <div class="lg:col-span-5">
      <div class="rounded-3xl overflow-hidden shadow-2xl h-full">
        <Image
          src={intro.sideImage}
          alt={intro.sideImageAlt?.[lang] ?? title}
          width={900}
          height={900}
          format="webp"
          quality={90}
          class="w-full h-full object-cover"
          loading="lazy"
        />
      </div>
    </div>
    <div class="lg:hidden col-span-1">
      <ProjectMeta
        year={year}
        industry={industry}
        yearLabel={yearLabel}
        industryLabel={industryLabel}
      />
    </div>
  </div>
) : (
  <div class="mb-10">
    <div class="flex flex-col lg:flex-row lg:items-start lg:gap-4 mb-8">
      <h1 class="[font-family:'Bricolage_Grotesque',Helvetica] font-bold text-[#13243c] text-3xl md:text-4xl lg:text-5xl leading-tight text-left">
        {title}
      </h1>
      {siteUrl && (
        <>
          <a
            href={siteUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="hidden lg:inline-flex items-center gap-2 bg-white text-[#211ee1] [font-family:'Bricolage_Grotesque',Helvetica] font-semibold text-sm px-5 py-2 rounded-full hover:bg-[#faf1ea] transition-colors whitespace-nowrap self-start mt-1"
          >
            <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M14 3h7v7M10 14L21 3M21 21H3V3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            {visitSiteLabel}
          </a>
          <div class="mt-4 lg:hidden">
            <a
              href={siteUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 bg-white text-[#211ee1] [font-family:'Bricolage_Grotesque',Helvetica] font-semibold text-base md:text-lg px-6 py-2 rounded-full hover:bg-[#faf1ea] transition-colors"
            >
              <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M14 3h7v7M10 14L21 3M21 21H3V3" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              {visitSiteLabel}
            </a>
          </div>
        </>
      )}
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 mb-10">
      <div>
        {paragraphs.map((p, i) => (
          <p
            class:list={[
              "[font-family:'Be_Vietnam',Helvetica] text-[#13243c] text-base md:text-lg leading-relaxed",
              i < paragraphs.length - 1 ? 'mb-4' : '',
            ]}
          >
            {p}
          </p>
        ))}
      </div>
      <div>
        <h2 class="[font-family:'Bricolage_Grotesque',Helvetica] font-bold text-[#13243c] text-xl md:text-2xl mb-4">
          {keyResultsLabel}
        </h2>
        <ul class="list-disc pl-5 space-y-2 [font-family:'Be_Vietnam',Helvetica] text-[#13243c] text-base md:text-lg leading-relaxed">
          {intro.results[lang].map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    </div>
    <ProjectMeta
      year={year}
      industry={industry}
      yearLabel={yearLabel}
      industryLabel={industryLabel}
      class="mb-0"
    />
  </div>
)}
