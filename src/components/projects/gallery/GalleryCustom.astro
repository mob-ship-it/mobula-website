---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  layout: string;
  images: ImageMetadata[];
  alts: string[];
}

const { layout, images, alts } = Astro.props;

/**
 * Named one-off layouts from design. Prefer full/split when possible.
 * Add a new `layout` branch here instead of hardcoding markup in the page.
 */
---

{layout === 'stack' ? (
  <div class="space-y-8 mb-8 lg:mb-12">
    {images.map((image, i) => (
      <div class="rounded-3xl overflow-hidden shadow-2xl">
        <Image
          src={image}
          alt={alts[i] ?? ''}
          width={1600}
          height={1000}
          format="webp"
          quality={90}
          class="w-full h-auto object-cover"
          loading="lazy"
        />
      </div>
    ))}
  </div>
) : (
  <div class="mb-8 lg:mb-12" data-gallery-custom={layout}>
    <p class="[font-family:'Be_Vietnam',Helvetica] text-[#13243c]/60 text-sm mb-4">
      Unsupported gallery layout: {layout}
    </p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {images.map((image, i) => (
        <div class="rounded-3xl overflow-hidden shadow-2xl">
          <Image
            src={image}
            alt={alts[i] ?? ''}
            width={900}
            height={900}
            format="webp"
            quality={90}
            class="w-full h-auto object-cover"
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </div>
)}
