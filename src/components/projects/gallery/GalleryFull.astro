---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  image: ImageMetadata;
  alt: string;
}

const { image, alt } = Astro.props;
---

<div class="mb-8 lg:mb-12">
  <div class="rounded-3xl overflow-hidden shadow-2xl">
    <Image
      src={image}
      alt={alt}
      width={1600}
      height={1000}
      format="webp"
      quality={90}
      class="w-full h-auto object-cover"
      loading="lazy"
    />
  </div>
</div>
