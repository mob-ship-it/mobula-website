---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { GalleryVisibility } from '../../../data/projects/types';

interface Props {
  image: ImageMetadata;
  alt: string;
  visibility?: GalleryVisibility;
}

const { image, alt, visibility = 'all' } = Astro.props;

const visibilityClass =
  visibility === 'mobile'
    ? 'lg:hidden'
    : visibility === 'desktop'
      ? 'hidden lg:block'
      : '';
---

<div class:list={['mb-8 lg:mb-12', visibilityClass]}>
  <div class="rounded-3xl overflow-hidden shadow-2xl">
    <Image
      src={image}
      alt={alt}
      width={1600}
      height={1000}
      format="webp"
      quality={90}
      class="w-full h-auto object-cover"
      loading="lazy"
    />
  </div>
</div>
