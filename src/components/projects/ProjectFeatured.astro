---
import { Image } from 'astro:assets';
import ProjectsCarousel from '../ProjectsCarousel.astro';
import type { ImageMetadata } from 'astro';

export type FeaturedProjectItem = {
  id: string;
  title: string;
  subtitle?: string;
  image: ImageMetadata;
  href: string;
};

interface Props {
  heading: string;
  projects: FeaturedProjectItem[];
}

const { heading, projects } = Astro.props;
---

<div class="hidden lg:block mb-16">
  <h3 class="[font-family:'Bricolage_Grotesque',Helvetica] font-bold text-[#13243c] text-2xl md:text-3xl mb-6">
    {heading}
  </h3>
  <ProjectsCarousel projects={projects} />
</div>

<div class="mb-8 lg:hidden">
  <h3 class="[font-family:'Bricolage_Grotesque',Helvetica] font-bold text-[#13243c] text-2xl md:text-3xl mb-8">
    {heading}
  </h3>
</div>

<div class="space-y-8 mb-12 lg:hidden">
  {projects.map((project) => (
    <a href={project.href} class="block my-6">
      <div class="rounded-3xl overflow-hidden shadow-lg mb-4">
        <Image
          src={project.image}
          alt={project.title}
          width={1200}
          height={800}
          format="webp"
          quality={85}
          class="w-full h-auto object-cover"
          loading="lazy"
        />
      </div>
      <p class="[font-family:'Bricolage_Grotesque',Helvetica] font-semibold text-[#13243c] text-lg">
        {project.title}
      </p>
      {project.subtitle && (
        <p class="[font-family:'Be_Vietnam',Helvetica] text-[#13243c]/70 text-base">
          {project.subtitle}
        </p>
      )}
    </a>
  ))}
</div>
