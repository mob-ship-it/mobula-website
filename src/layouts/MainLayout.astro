---
import Header from '../components/Header.astro';
import AnimatedCursor from '../components/AnimatedCursor.jsx';
import ScrollButtons from '../components/ScrollButtons.astro';
import { Image } from 'astro:assets';
import arrowImage from '../assets/images/mockups/Layer_1.png';
import '../styles/global.css';
import '../styles/carousel-animations.css';
import Footer from '../components/Footer.astro';
import { SITE_URL } from '../config/site';
import { getLangFromUrl, getAlternateLangPath } from '../i18n/utils';
import { ui } from '../i18n/ui';

const { title = "Mobula Studio", description: propDescription } = Astro.props;
const pathname = Astro.url?.pathname || '/';
const isHome = pathname === '/' || pathname === '/en' || pathname === '/en/';
const lang = getLangFromUrl(Astro.url);

// Meta description: prop o inferida por ruta
const pathNorm = pathname.replace(/^\/en\/?/, '/').replace(/\/+$/, '') || '/';
const descriptionKeyByPath: Record<string, string> = {
  '/': 'seo.home.description',
  '/proyectos': 'seo.projects.description',
  '/projects': 'seo.projects.description',
  '/brief': 'seo.brief.description',
  '/LegalLawOffice': 'seo.legal.description',
  '/Stanzza': 'seo.stanzza.description',
  '/ECPConsultingGroup': 'seo.ecp.description',
  '/KaseCab': 'seo.kase.description',
};
const descriptionKey = descriptionKeyByPath[pathNorm] || 'seo.home.description';
const description = propDescription ?? (ui[lang] as Record<string, string>)[descriptionKey] ?? (ui.es as Record<string, string>)['seo.home.description'];

// Canonical: URL absoluta sin query
const canonicalPath = pathname.replace(/\/+$/, '') || '/';
const canonicalUrl = `${SITE_URL}${canonicalPath}`;

// Hreflang: URLs alternativas ES y EN
const pathEs = getAlternateLangPath(Astro.url, 'es');
const pathEn = getAlternateLangPath(Astro.url, 'en');
const urlEs = `${SITE_URL}${pathEs}`;
const urlEn = `${SITE_URL}${pathEn}`;
const urlXDefault = `${SITE_URL}${pathEs}`;
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="alternate" hreflang="es" href={urlEs} />
  <link rel="alternate" hreflang="en" href={urlEn} />
  <link rel="alternate" hreflang="x-default" href={urlXDefault} />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload" href="https://fonts.googleapis.com/css?family=Bricolage+Grotesque:500,400,600|Be+Vietnam:500,400,700&display=swap" as="style" onload="this.rel='stylesheet'">
  <noscript>
    <link href="https://fonts.googleapis.com/css?family=Bricolage+Grotesque:500,400,600|Be+Vietnam:500,400,700&display=swap" rel="stylesheet">
  </noscript>

  <link rel="preload" href="https://cdnjs.cloudflare.com/ajax/libs/meyer-reset/2.0/reset.min.css" as="style" onload="this.rel='stylesheet'">
  <noscript>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/meyer-reset/2.0/reset.min.css" rel="stylesheet">
  </noscript>
  <meta name="theme-color" content="#ffffff">
  <link rel="manifest" href="/site.webmanifest">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="icon" href="/favicon.ico">
  <style is:global>
    * {
      -webkit-font-smoothing: antialiased;
      box-sizing: border-box;
    }
    html,
    body {
      margin: 0px;
      height: 100%;
    }
    button:focus-visible {
      outline: 2px solid #4a90e2 !important;
      outline: -webkit-focus-ring-color auto 5px !important;
    }
    a {
      text-decoration: none;
    }
  </style>
</head>
<body class="bg-[#faf1ea]">
  <div class="relative min-h-screen flex flex-col overflow-x-hidden">
  <AnimatedCursor client:idle />

    <!-- Global Background Arrow (Layer_1.png) - hidden on small screens -->
    <div aria-hidden="true" class="pointer-events-none fixed z-0 select-none hidden md:block" style="top: -125px; right: 0px;">
      <Image 
        src={arrowImage} 
        alt="" 
        width={1600} 
        height={1600} 
        format="webp"
        quality={80}
        loading="eager"
        class="w-auto h-auto object-contain block" 
        style="width: min(52vw, 1200px)" 
      />
    </div>

    <!-- App Shell -->
    <div class="relative z-10 flex flex-col min-h-screen">
      <Header showLeftLogo={!isHome} />
      <!-- Reserve space for the fixed header so page content isn't hidden behind it -->
      <main class="flex-1 pt-16 lg:pt-14">
        <slot />
      </main>
      <!-- Footer estático -->
      <Footer />
    </div>
    <!-- Scroll Buttons -->
    <ScrollButtons />
  </div>
</body>
</html>
