---
import MainLayout from '../../layouts/MainLayout.astro';
import BriefContentForm from '../../components/BriefContentForm';
import * as i18n from '../../i18n/utils';

const lang = i18n.getLangFromUrl(Astro.url);
const t = i18n.useTranslations(lang);
---

<MainLayout title={`${t('briefContent.form.title')} - Mobula Estudio`}>
  <BriefContentForm client:load lang={lang} />
</MainLayout>
